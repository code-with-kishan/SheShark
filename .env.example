# SheShark Platform - Environment Configuration

# ========== SERVER SETTINGS ==========
PORT=3000
NODE_ENV=development

# ========== API KEYS ==========
# Get your API key from: https://console.cloud.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ========== JWT CONFIGURATION ==========
JWT_SECRET=your_very_secure_jwt_secret_key_change_in_production

# ========== DATABASE CONFIGURATION ==========
# Option 1: MongoDB with Mongoose
# MONGODB_URI=mongodb://localhost:27017/sheshark
# Or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/sheshark

# Option 2: PostgreSQL with Prisma
# DATABASE_URL=postgresql://user:password@localhost:5432/sheshark

# ========== FILE STORAGE ==========
# AWS S3
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret
# AWS_S3_BUCKET=sheshark-uploads
# AWS_REGION=us-east-1

# Cloudinary
# CLOUDINARY_CLOUD_NAME=your_cloudinary_name
# CLOUDINARY_API_KEY=your_cloudinary_key
# CLOUDINARY_API_SECRET=your_cloudinary_secret

# ========== FIREBASE (optional) ==========
# FIREBASE_API_KEY=your_firebase_key
# FIREBASE_AUTH_DOMAIN=your_app.firebaseapp.com
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_STORAGE_BUCKET=your_app.appspot.com
# FIREBASE_MESSAGING_SENDER_ID=your_sender_id
# FIREBASE_APP_ID=your_app_id

# ========== COMMUNICATION SERVICES ==========
# Twilio (for SMS alerts)
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_token
# TWILIO_PHONE_NUMBER=+1234567890

# SendGrid (for email)
# SENDGRID_API_KEY=your_sendgrid_key

# ========== EXTERNAL SERVICES ==========
# Google Maps API
# GOOGLE_MAPS_API_KEY=your_maps_key

# Stripe (for payments)
# STRIPE_PUBLIC_KEY=your_stripe_public_key
# STRIPE_SECRET_KEY=your_stripe_secret_key

# ========== LOGGING ==========
LOG_LEVEL=info

# ========== FRONTEND SETTINGS ==========
# This adds CORS headers in development
VITE_API_BASE_URL=http://localhost:3000
 
